name: Build APK and Deploy

on:
  push:
    branches:
      - main

permissions:
  contents: read
  pages: write
  id-token: write

jobs:
  build:
    runs-on: ubuntu-latest

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Setup Java
        uses: actions/setup-java@v4
        with:
          distribution: temurin
          java-version: 17

      - name: Grant execute permission
        run: chmod +x gradlew

      - name: Build APK
        run: ./gradlew assembleDebug

      - name: Prepare website
        run: |
          mkdir public
          cp app/build/outputs/apk/debug/app-debug.apk public/

          echo "<html><body>" > public/index.html
          echo "<h1>Download APK</h1>" >> public/index.html
          echo "<a href='app-debug.apk'>Download App</a>" >> public/index.html
          echo "</body></html>" >> public/index.html

      - name: Setup GitHub Pages
        uses: actions/configure-pages@v5

      - name: Upload artifact
        uses: actions/upload-pages-artifact@v3
        with:
          path: public

      - name: Deploy to GitHub Pages
        uses: actions/deploy-pages@v4
